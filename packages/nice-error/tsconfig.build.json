{
  "extends": "./tsconfig.json",
  "include": [
    "src"
  ],
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "src",
    "outDir": "build/types",
    "stripInternal": true
  },
  "exclude": [
    "**/*.test.ts",
    "**/*.test-d.ts"
  ]
}