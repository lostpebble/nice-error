{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "esnext",
    "module": "esnext",
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "bun"
    ],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "noPropertyAccessFromIndexSignature": true,
    "moduleDetection": "force",
    "paths": {
      "@nice-error/core": [
        "../core/src/index.ts"
      ],
      "@nice-error/common-errors": [
        "../common-errors/src/index.ts"
      ],
      "@nice-error/nice-action": [
        "../nice-action/src/index.ts"
      ]
    }
  },
  "include": [
    "src"
  ]
}