{
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "bun"
    ],
    "paths": {
      "@nice-code/error": [
        "../nice-error/src/index.ts"
      ],
      "@nice-code/action": [
        "../nice-action/src/index.ts"
      ]
    }
  }
}