{
  "name": "demo-backend",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types && bunx @biomejs/biome format . --write",
    "dev": "bun run cf-typegen && wrangler dev",
    "start": "bun run src/pure_bun/ws_server.ts",
    "type-check": "bunx tsc --noEmit",
    "type-check-watch": "bunx tsc --noEmit --watch"
  },
  "type": "module",
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@nice-code/common-errors": "workspace:*",
    "@nice-code/error": "workspace:*",
    "@nice-code/action": "workspace:*",
    "@nice-code/connect": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "demo-shared": "workspace:*",
    "hono": "^4.12.15",
    "http-status-codes": "^2.3.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "wrangler": "^4.85.0"
  }
}
