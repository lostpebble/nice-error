{
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "./worker-configuration.d.ts",
      "bun"
    ],
    "paths": {
      "@nice-error/core": [
        "../core/src/index.ts"
      ],
      "@nice-error/common-errors": [
        "../common-errors/src/index.ts"
      ],
      "@nice-error/common-errors/hono": [
        "../common-errors/src/hono/index.ts"
      ],
      "@nice-error/nice-action": [
        "../nice-action/src/index.ts"
      ]
    }
  }
}