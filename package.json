{
  "name": "@nice-error/monorepo",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "errors",
    "typescript",
    "javascript",
    "error",
    "error handling",
    "error management",
    "error utilities",
    "error library"
  ],
  "scripts": {
    "format": "biome check --write .",
    "type-check-all": "bun run --filter '*' type-check",
    "build-all": "bun run --filter '@nice-error/*' build",
    "vitest-all": "bun run --filter '*' vitest",
    "lint": "bunx @biomejs/biome check . && eslint ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "eslint": "^10.2.0",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.58.1"
  }
}
